RewriteEngine On

# CORS is handled per-endpoint in PHP (needed for session cookies with credentials:include).
# A wildcard '*' here would block cookies from working, so we let PHP set the correct headers.

# Preflight requests (PHP handles the headers)
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]


# ==========================================
# SUPERADMIN ROUTES
# ==========================================
RewriteRule ^instituicoes/(.*)$ superadmin/instituicoes.php?id=$1 [QSA,L]
RewriteRule ^instituicoes$ superadmin/instituicoes.php [QSA,L]

# ==========================================
# ADMIN ROUTES
# ==========================================
# Permite a API do admin sem precisar bater na pasta
RewriteRule ^instituicao/logo\.php$ admin/instituicao_logo.php [QSA,L]
RewriteRule ^admin/embed\.php$ admin/embed.php [QSA,L]

RewriteRule ^videos/([0-9]+)/questions/?$ admin/questions.php?videoId=$1 [QSA,L]
RewriteRule ^videos/([0-9]+)/?$ admin/videos.php?id=$1 [QSA,L]
RewriteRule ^videos\.php$ admin/videos.php [QSA,L]

RewriteRule ^questions/([0-9]+)/?$ admin/questions.php?id=$1 [QSA,L]
RewriteRule ^questions\.php$ admin/questions.php [QSA,L]

RewriteRule ^cursos/([0-9]+)/?$ admin/cursos.php?id=$1 [QSA,L]
RewriteRule ^cursos\.php$ admin/cursos.php [QSA,L]

RewriteRule ^modulos/([0-9]+)/?$ admin/modulos.php?id=$1 [QSA,L]
RewriteRule ^modulos\.php$ admin/modulos.php [QSA,L]

# ==========================================
# STUDENT ROUTES
# ==========================================
RewriteRule ^student/video$ student/video.php [QSA,L]
RewriteRule ^student/progress$ student/progress.php [QSA,L]
RewriteRule ^student/answer$ student/answer.php [QSA,L]

# Fallbacks for root api files if they forget .php
RewriteRule ^auth$ auth.php [QSA,L]
RewriteRule ^register$ register.php [QSA,L]
